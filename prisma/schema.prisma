// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         String   @default("worker") // "worker" | "admin"
  isVerified   Boolean  @default(false)
  vaultKeyHash String?
  createdAt    DateTime @default(now())

  documents       Document[]
  analysisResults AnalysisResult[]
  auditLogs       AuditLog[]
}

model Document {
  id          String   @id @default(cuid())
  ownerId     String
  filename    String
  contentType String
  sizeBytes   Int
  storagePath String
  createdAt   DateTime @default(now())

  owner           User             @relation(fields: [ownerId], references: [id])
  analysisResults AnalysisResult[]
}

model AnalysisResult {
  id            String   @id @default(cuid())
  documentId    String
  ownerId       String
  geminiRawJson String
  extractedJson String
  piiJson       String
  redactedJson  String
  createdAt     DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id])
  owner    User     @relation(fields: [ownerId], references: [id])
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  action       String
  resourceType String?
  resourceId   String?
  ip           String?
  userAgent    String?
  details      String?
  createdAt    DateTime @default(now())

  actor User? @relation(fields: [actorUserId], references: [id])
}